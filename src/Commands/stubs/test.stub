<?php

use {resourceNamespace}\{modelName}Resource;
use {modelNamespace}\{modelName};

beforeEach(function () {
    $this->initialize(
        {modelName}::class,
        {modelName}Resource::class,
        '{baseRouteName}', // the named route eg: 'user.products.' //!!! Note: the dot "." in the end of the baseUrl is important !!!
        '{{actor}}',  // define the actor
        [] // if your endpoints return the model with its relation put the relations in the array
    );
});

it('Test User Can Index {modelName}', function () {
    $this->requestPathHook($this->baseUrl . 'index');
    $this->indexTest();
});

it('Test User Can Show A {modelName}', function () {
    $this->requestPathHook($this->baseUrl . 'show');
    $this->showTest();
});

it('Test User Can Create A {modelName}', function () {
    $this->requestPathHook($this->baseUrl . 'store');
    $this->storeTest([{additionalFactoryData}]);
});

it('Test User Can Update {modelName}', function () {
    $this->requestPathHook($this->baseUrl . 'update');
    $this->updateTest([{additionalFactoryData}]);
});

it('Test User Can delete A {modelName}', function () {
    $this->requestPathHook($this->baseUrl . 'destroy');
    $this->deleteTest();
});
